{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "env": [
        "NEXT_PUBLIC_*",
        "SUPABASE_*",
        "STRIPE_*",
        "SENTRY_*",
        "POSTHOG_*"
      ],
      "outputs": [
        ".next/**",
        "dist/**",
        "build/**",
        ".expo/**",
        "!.expo/README.md"
      ],
      "cache": true
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "env": [
        "NEXT_PUBLIC_*",
        "SUPABASE_*",
        "EXPO_PUBLIC_*"
      ],
      "outputs": []
    },
    "lint": {
      "dependsOn": ["^lint"],
      "env": [
        "NEXT_PUBLIC_*",
        "SUPABASE_*",
        "EXPO_PUBLIC_*"
      ],
      "outputs": []
    },
    "test": {
      "dependsOn": ["^test"],
      "env": [
        "NEXT_PUBLIC_*",
        "SUPABASE_*",
        "EXPO_PUBLIC_*",
        "NODE_ENV"
      ],
      "outputs": [
        "coverage/**",
        "dist/**"
      ]
    }
  }
}
