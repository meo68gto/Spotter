{
  "expo": {
    "name": "Spotter",
    "slug": "spotter",
    "version": "0.1.0",
    "scheme": "spotter",
    "jsEngine": "jsc",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.spotter.app",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Spotter uses your location to find nearby activity matches.",
        "NSUserNotificationUsageDescription": "Spotter sends notifications for round invitations, messages, and important updates.",
        "UIBackgroundModes": ["remote-notification"]
      }
    },
    "android": {
      "package": "com.spotter.app",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "RECEIVE_BOOT_COMPLETED",
        "WAKE_LOCK"
      ],
      "notification": {
        "icon": "./assets/notification-icon.png",
        "color": "#102a43",
        "sound": true
      }
    },
    "plugins": [
      [
        "@stripe/stripe-react-native",
        {
          "merchantIdentifier": "merchant.com.spotter.app",
          "enableGooglePay": false
        }
      ],
      "expo-apple-authentication",
      "@sentry/react-native/expo",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#102a43",
          "sounds": ["./assets/notification-sound.wav"]
        }
      ]
    ],
    "extra": {
      "eas": {
        // ⚠️  Replace with your actual EAS project ID from `eas project:create` or `eas project:configure`.
        // A fake UUID here will cause EAS Build to fail or mis-route artifacts.
        "projectId": "REPLACE_WITH_EAS_PROJECT_ID"
      }
    }
  }
}
