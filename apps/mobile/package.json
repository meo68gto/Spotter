{
  "name": "@spotter/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "dev": "EXPO_NO_DOCTOR=1 EXPO_NO_DEPENDENCY_VALIDATION=1 expo start --clear",
    "dev:offline": "EXPO_OFFLINE=1 EXPO_NO_DOCTOR=1 EXPO_NO_DEPENDENCY_VALIDATION=1 expo start --offline --clear",
    "ios": "expo run:ios",
    "android": "expo run:android",
    "web": "expo start --web",
    "build": "expo export",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "e2e:build:ios": "detox build --configuration ios.sim.debug",
    "e2e:test:ios": "detox test --configuration ios.sim.debug --record-logs all --take-screenshots failing",
    "e2e:build:android": "detox build --configuration android.emu.debug",
    "e2e:test:android": "detox test --configuration android.emu.debug --record-logs all --take-screenshots failing"
  },
  "dependencies": {
    "@babel/runtime": "^7.25.0",
    "@expo/metro-runtime": "~4.0.1",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@spotter/env": "workspace:*",
    "@spotter/types": "workspace:*",
    "@stripe/stripe-react-native": "^0.49.0",
    "@supabase/supabase-js": "^2.49.1",
    "expo": "~52.0.17",
    "expo-apple-authentication": "~7.0.1",
    "expo-asset": "~11.0.5",
    "expo-auth-session": "~6.0.3",
    "expo-file-system": "~18.0.4",
    "expo-haptics": "~14.0.1",
    "expo-image-picker": "~16.0.4",
    "expo-linking": "~7.0.3",
    "expo-location": "~18.0.4",
    "expo-secure-store": "~14.0.1",
    "expo-status-bar": "~2.0.1",
    "expo-web-browser": "~14.0.2",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-native": "0.76.9",
    "react-native-gesture-handler": "~2.20.2",
    "react-native-maps": "^1.20.1",
    "react-native-reanimated": "~3.16.1",
    "react-native-svg": "^15.10.0",
    "react-native-url-polyfill": "^2.0.0",
    "react-native-web": "~0.19.13",
    "react-native-webview": "^13.15.0",
    "@sentry/react-native": "^5.33.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@types/react": "~18.3.12",
    "@types/react-native": "^0.73.0",
    "@types/jest": "^29.5.13",
    "babel-preset-expo": "~12.0.0",
    "detox": "^20.27.0",
    "eslint": "^9.17.0",
    "jest": "^29.7.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.9"
  }
}
